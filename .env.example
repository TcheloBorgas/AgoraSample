APP_HOST=127.0.0.1
APP_PORT=8000
TIMEZONE=America/Sao_Paulo

# Deploy rápido (Render): GEMINI_API_KEY + modelo; sem Mongo por defeito (dados em RAM no processo).
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB_NAME=voice_assistant_mvp
# USE_MONGO=false


# Google Calendar OAuth (credentials.json na raiz)
GOOGLE_CLIENT_SECRET_FILE=credentials.json
GOOGLE_TOKEN_FILE=data/google_token.json
GOOGLE_CALENDAR_ID=primary

# Agora RTC
AGORA_APP_ID=
# Certificado do projeto (Console Agora) — gera token válido a cada pedido; preferível a AGORA_TEMP_TOKEN
AGORA_APP_CERTIFICATE=
# Só se não usar certificado: token do console (expira em poucos minutos)
AGORA_TEMP_TOKEN=
AGORA_CHANNEL_PREFIX=assistant-voice
AGORA_FIXED_CHANNEL=Agora
AGORA_UID=10001

# Conversational AI Engine (REST)
AGORA_CAE_ENABLED=true
AGORA_CAE_CUSTOMER_ID=
AGORA_CAE_CUSTOMER_SECRET=
AGORA_CAE_AGENT_UID=20001
AGORA_CAE_AGENT_NAME_PREFIX=assistant-cae
AGORA_CAE_ENABLE_TOOLS=true

# URL publica (ngrok/cloudflared) para callback do LLM e MCP
AGORA_CAE_PUBLIC_BASE_URL=
AGORA_CAE_MCP_ENDPOINT=

# Opcional: LLM CAE (OpenAI-compatible). Se vazio, usa GEMINI_* ou LLM_OPENAI_COMPAT_* abaixo.
AGORA_CAE_EXTERNAL_LLM_URL=
AGORA_CAE_EXTERNAL_LLM_API_KEY=
# Modelo real da API (ex. llama-3.1-8b-instant no Groq, gpt-4o-mini na OpenAI)
AGORA_CAE_EXTERNAL_LLM_MODEL=

# TTS para CAE: openai exige AGORA_CAE_TTS_OPENAI_KEY; microsoft exige Azure; elevenlabs exige key
AGORA_CAE_TTS_VENDOR=openai

# OpenAI TTS (recomendado - mais acessivel)
AGORA_CAE_TTS_OPENAI_KEY=
AGORA_CAE_TTS_OPENAI_MODEL=gpt-4o-mini-tts
AGORA_CAE_TTS_OPENAI_VOICE=coral

# Alternativa: Microsoft Azure TTS
AGORA_CAE_TTS_AZURE_KEY=
AGORA_CAE_TTS_AZURE_REGION=

# Alternativa: ElevenLabs TTS
AGORA_CAE_TTS_ELEVENLABS_KEY=
AGORA_CAE_TTS_ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
AGORA_CAE_TTS_ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Mínimo para LLM online grátis (Google AI Studio): https://aistudio.google.com/apikey
# Cobre chat "unknown" e o LLM do CAE se AGORA_CAE_PUBLIC_BASE_URL / EXTERNAL_LLM estiverem vazios.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Opcional: Groq / OpenRouter (os três preenchidos têm precedência sobre GEMINI_*)
# LLM_OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# LLM_OPENAI_COMPAT_API_KEY=
# LLM_OPENAI_COMPAT_MODEL=llama-3.1-8b-instant
# LLM_OPENAI_COMPAT_TIMEOUT=60

# Ollama local (se nada acima estiver ativo ou falhar)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral

# =============================================================================
# SCHEDULER_API_BASE — só no Netlify (Build environment), não no uvicorn
# =============================================================================
# No painel: Site configuration → Environment variables → Add variable
#   Name:  SCHEDULER_API_BASE
#   Value: URL pública do FastAPI, SEM barra no fim
#   Ex.:    https://seu-app.railway.app
# Isto alimenta o script `node scripts/netlify-build-web.mjs`: gera `web/_redirects`
# para proxy `/api/*` → `${SCHEDULER_API_BASE}/api/*`. Novo deploy após alterar.
#
# Teste local com `web/` noutra origem: em `web/runtime-config.js` use
#   window.__SCHEDULER_API_BASE__ = "http://127.0.0.1:8000";
# (ou sirva UI pelo mesmo host que o uvicorn — aí pode ficar vazio.)
#
# SCHEDULER_API_BASE=https://seu-app.railway.app
